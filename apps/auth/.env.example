# Environment variables needed for apps/auth

# Supabase (Wildcard Domain Configured in packages/auth)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Central Database (Temporarily pointing to root DB)
DATABASE_URL=your_postgres_pool_url
DIRECT_URL=your_postgres_direct_url

# Resend (for Auth Emails)
RESEND_API_KEY=your_resend_key

# Cookie Domain (Important for cross-subdomain auth)
NEXT_PUBLIC_COOKIE_DOMAIN=.sharufa.com # Leave empty for localhost

# App URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3001 # Or https://login.sharufa.com
