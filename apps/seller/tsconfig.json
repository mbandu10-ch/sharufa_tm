{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*", "../../src/*"],
      "@root/*": ["../../src/*"],
      "@components/*": ["../../src/components/*"],
      "@sharufa/shared": ["../../packages/shared"],
      "@sharufa/ui": ["../../packages/ui"],
      "@sharufa/auth": ["../../packages/auth"],
      "@sharufa/db": ["../../packages/db"],
      "@sharufa/emails": ["../../packages/emails"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
